{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReFx Desktop",
  "version": "0.1.8",
  "identifier": "gg.refx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ReFx Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["refx"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/ReFxFrank/ReFx-Remote/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3MDVGOTRENTg3MzM3RkYKUldUL04zTllUZmtGaDJMZGpoRFEvTlV6V0ptZXZzOXI5QjRlQnRMdTAvMkhqUDNuNUxKTlZHNkcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "publisher": "ReFx Hosting",
    "shortDescription": "Manage your ReFx game servers from your desktop.",
    "longDescription": "ReFx Desktop lets ReFx Hosting customers operate their game servers natively: live console, power controls, files, backups, and crash alerts — without opening the web panel.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
